# ─── Clever Gateway environment ───

# Core
CG_ENV=development
CG_HTTP_PORT=8080
CG_LOG_LEVEL=INFO

# Master key for bootstrap / admin operations
CG_MASTER_KEY=sk-cg-master-change-me

# JWT (admin auth)
CG_JWT_SECRET=change-this-jwt-secret
CG_JWT_ALGORITHM=HS256
CG_JWT_ACCESS_EXPIRE_MINUTES=15
CG_JWT_REFRESH_EXPIRE_DAYS=7

# Encryption key for provider keys (Fernet) — generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CG_ENCRYPTION_KEY=

# Admin seed
CG_ADMIN_USERNAME=salman
CG_ADMIN_PASSWORD=136517
CG_ADMIN_EMAIL=olddealers@gmail.com
CG_ADMIN_FIRST_NAME=Salman
CG_ADMIN_LAST_NAME=JB

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://cg:cg@localhost:5432/clever_gateway

# Redis
REDIS_URL=redis://localhost:6379/0

# LiteLLM router defaults
CG_ROUTING_STRATEGY=simple-shuffle
CG_NUM_RETRIES=3
CG_TIMEOUT=60
CG_ALLOWED_FAILS=3
CG_COOLDOWN_TIME=60

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
