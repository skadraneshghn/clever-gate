# ─── Clever Gateway — root .gitignore ─────────────────────────────────────────

# Secrets — NEVER commit
.env
.env.local
.env.production

# Python
backend/.venv
backend/__pycache__
backend/**/__pycache__
**/__pycache__
**/*.pyc
**/*.pyo
backend/.pytest_cache
backend/.mypy_cache
backend/.ruff_cache
backend/.coverage
backend/htmlcov/
*.egg-info/
dist/
build/

# Node / Next.js
frontend/node_modules
frontend/.next
frontend/out
frontend/.turbo

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Docker local artifacts
*.tar

# Logs
*.log
/tmp/
